# ---------------------------------------------------------------------------
# Environment configuration template.
#
# Copy this file to ".env" (which is git-ignored) and fill in values.
# In Phase 0 the app boots fine with everything left blank — keys are only
# REQUIRED once the agents start making LLM calls in Phase 1.
# ---------------------------------------------------------------------------

# Which LLM provider the agents use by default: "groq" or "gemini".
LLM_PROVIDER=groq

# --- Groq (default provider) ----------------------------------------------
# Free tier, fast inference. Create a key at: https://console.groq.com/keys
# (sign in, "Create API Key", copy the value here).
GROQ_API_KEY=

# --- Google Gemini (fallback provider) ------------------------------------
# Free tier. Create a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Persistence ----------------------------------------------------------
# SQLAlchemy database URL. Default is a local SQLite file (zero setup).
# To use Postgres (e.g. Neon free tier) later, just change this URL, e.g.:
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME
DATABASE_URL=sqlite:///storage/redteam.db

# --- Observability (Langfuse) — OPTIONAL ----------------------------------
# Trace every agent call (tokens, latency, cost). Leave blank to disable.
# Free tier: create a project at https://cloud.langfuse.com -> Settings ->
# API Keys -> create. Copy the public (pk-lf-...) and secret (sk-lf-...) keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App metadata (optional overrides) ------------------------------------
ENVIRONMENT=dev
